# =============================================================================
# Solo Suite — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- Google OAuth (Required for login) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google as authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth.js (Required for login) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Google Sheets (Optional: Workspace Database) ---
# Create a Google Sheet and paste its ID (from the URL: /spreadsheets/d/<SHEET_ID>)
# Create a service account at https://console.cloud.google.com/apis/credentials
# then share the sheet with the service account email.
# Leave SHEET_ID empty to use InMemoryDatabase (dev mode — data resets on restart)
SHEET_ID=
GOOGLE_SERVICE_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- MCP AI Provider (Optional) ---
# Endpoint and API key for the Model Context Protocol provider
MCP_ENDPOINT=
MCP_API_KEY=
